@model MyAccountViewModel

@{
    ViewData["Title"] = "My Account";
}

<div class="container"> 
    <div class="myAccount-page">
        <section class="myAccount-section1">
            <h3 class="myAccount-sectionTitle1">My Account</h3>
        </section>

        <section class="myAccount-section2">
            <div class="myAccount-ls">
                <aside class="myAccount-sidebar">
            
                    <div class="profileImage-wrapper">
                        <img src="@Model.AboutMeForm.ProfileImageUrl" alt="Profile Image" />
                    </div>
            
                    <div class="myAccount-sidebar-menu">
                        <div class="sidebarMenue-row1">
                            <p class="sidebarMenue-row1-txt">Menu Options</p>
                        </div>
                        <div class="sidebarMenue-row2">
                            <a asp-controller="" asp-action="" class="myAccount-sidebar-link">About Me <div class="myAccount-linkIcon"><i class="fa-solid fa-angle-right"></i></div></a>
                            
                            <a asp-controller="" asp-action="" class="myAccount-sidebar-link">My Membership <div class="myAccount-linkIcon"><i class="fa-solid fa-angle-right"></i></div></a>
                            
                            <a asp-controller="" asp-action="" class="myAccount-sidebar-link">My Bookings <div class="myAccount-linkIcon"><i class="fa-solid fa-angle-right"></i></div></a>

                            <form asp-action="SignOut" asp-controller="Authentication" method="post">
                                <button type="submit" class="myAccount-sidebar-signOutBtn">
                                    Sign Out <div class="myAccount-btnIcon"></><i class="fa-solid fa-angle-right"></i></div>
                                </button>
                            </form>
                        </div>
                    </div>

                    <div class="myAccount-sideBar-cancellationTxt">
                        <p class="cancellation-txt">If you like to cancel your account click below</p>
                    </div>

                    <section class="myAccount-deleteUser">
                        <form asp-action="DeleteUser" asp-controller="Authentication" method="Post">
                            <button class="deleteUser-btn">Remove Account</button>
                        </form>
                    </section>

                </aside>
            </div>

            <div class="myAccount-rs">

                <div class="aboutMeForm-wrapper">
                    <form class="aboutMe-form" asp-action="My" asp-controller="Account" method="post" enctype="multipart/form-data" novalidate>

                        <h3 class="aboutMe-form-h3">About Me</h3>

                        <hr class="aboutMe-form-line1" />

                        @if (!string.IsNullOrWhiteSpace(ViewData["ErrorMessage"]?.ToString()))
                        {
                            <p class="error-message">
                                @ViewData["ErrorMessage"]
                            </p>
                        }
                        else if (!string.IsNullOrWhiteSpace(ViewData["SuccessMessage"]?.ToString()))
                        {
                            <p class="success-message">
                                @ViewData["SuccessMessage"]
                            </p>
                        }

                        <div class="aboutMe-formGroup ">
                            <label class="aboutMeForm-label" asp-for="AboutMeForm.FirstName"></label>
                            <input class="aboutMeForm-input" asp-for="AboutMeForm.FirstName" />
                            <span class="aboutMeForm-validation-error" asp-validation-for="AboutMeForm.FirstName"></span>
                        </div>

                        <div class="aboutMe-formGroup two">
                            <label class="aboutMeForm-label" asp-for="AboutMeForm.LastName"></label>
                            <input class="aboutMeForm-input" asp-for="AboutMeForm.LastName" />
                            <span class="aboutMeForm-validation-error" asp-validation-for="AboutMeForm.LastName"></span>
                        </div>

                        <div class="aboutMe-formGroup three">
                            <label class="aboutMeForm-label" asp-for="Email"></label>
                            <input class="aboutMeForm-input" asp-for="Email" disabled/>
                        </div>

                        <div class="aboutMe-formGroup four">
                            <label class="aboutMeForm-label" asp-for="AboutMeForm.PhoneNumber"></label>
                            <input class="aboutMeForm-input" asp-for="AboutMeForm.PhoneNumber" />
                            <span class="aboutMeForm-validation-error" asp-validation-for="AboutMeForm.PhoneNumber"></span>
                        </div>

                        <hr class="aboutMe-form-line2" />

                        <div class="aboutMe-formGroup five">
                            <label class="aboutMeForm-label" asp-for="AboutMeForm.ProfileImageUrl"></label>
                            <input class="aboutMeForm-input" type="file" asp-for="AboutMeForm.ProfileImageUrl"/>
                            <span class="aboutMeForm-validation-error" asp-validation-for="AboutMeForm.ProfileImageUrl"></span>
                        </div>

                        <div class="aboutMeFormBtn-wrapper">
                            <button class="aboutMeForm-btn" type="submit">

                                <div class="aboutMeForm-submitBtnTxt">Save</div>

                                <div class="aboutMeForm-btnIcon">
                                    <i class="fa-solid fa-angle-right" style="color: #27252f;"></i>
                                </div>

                            </button>
                        </div>

                    </form>
                </div>

                <div class="myStatisticsForm-wrapper">

                    <h4 class="aboutMe-form-h4">My Statistics</h4>

                    <div class="myStatisticsForm">

                        <div class="myStatistics-label-wrapper">
                            <div class="myStatistics-label">Check-In (last 30 days)</div>
                            <div class="myStatistics-label-number">25</div>
                        </div>

                        <!-- Statistics bar -->
                        <div class="myStatistics-bar1">
                            <div class="myStatistics-progressBar1"></div>
                        </div> 

                        <div class="myStatistics-label-wrapper">
                            <div class="myStatistics-label">Weight Goal</div>
                            <div class="myStatistics-label-number">50%</div>
                        </div>

                        <!-- Statistics bar -->
                        <div class="myStatistics-bar2">
                            <div class="myStatistics-progressBar2"></div>
                        </div>

                        <div class="myStatistics-label-wrapper">
                            <div class="myStatistics-label">Current BMI</div>
                            <div class="myStatistics-label-number">27</div>
                        </div>

                        <!-- Statistics bar -->
                        <div class="myStatistics-bar3">
                            <div class="myStatistics-progressBar3"></div>
                        </div>

                    </div>

                </div>
            </div>
        </section>
    </div>
</div>