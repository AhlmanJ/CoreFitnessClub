
<div class="container">
    <section class="notFound-page">
        <div class="notFound-page-wrapper">
            <img class="notFound-page-img" src="~/images/404page/404-error-img1.svg" alt="A image with the number 404" />
            <h1 class="notFound-page-h1">Oops! page not found</h1>
            <p class="notFound-page-p">The page you are looking for does not exists.</p>
            <a asp-controller="Home" asp-action="index" class="notFound-page-btn">
                <h2 class="notFound-page-btnTxt">Back to Homepage</h2>
                <div class="notFound-page-btnIcon">
                    <i class="fa-solid fa-angle-right" style="color: #27252f;"></i>
                </div>
            </a>
        </div>
    </section>
</div>