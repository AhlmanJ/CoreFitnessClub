
<!-- I got help by chatGPT to create the dropdown menue in the form on row 86 -->

@model TrainingSessionViewModel

@{
    ViewData["Title"] = "Manage Training Session";
}

<div class="container">

    <div class="manageTrainingSession-page">

        <div class="manageTrainingSession-wrapper">

            <h3 class="manageTrainingSession-h3"> Manage Member Roles And Training Session </h3>

            @if (!string.IsNullOrWhiteSpace(TempData["ErrorMessage"]?.ToString()))
            {
                <p class="error-message">
                    @TempData["ErrorMessage"]
                </p>
            }
            else if (!string.IsNullOrWhiteSpace(TempData["SuccessMessage"]?.ToString()))
            {
                <p class="success-message">
                    @TempData["SuccessMessage"]
                </p>
            }

            <hr class="manageTrainingSession-line" />

            @if (!Model.Sessions.Any())
            {
                <div class="manageTrainingSession-noMembershipTxt-wrapper">
                    <h3 class="manageTrainingSession-h3">No active Training sessions</h3>
                </div>

                <hr class="manageTrainingSession-line" />
            }
            else
            {
                <div class="manageTrainingSession-list-wrapper">
                    @foreach (var Session in Model.Sessions)
                    {
                        <div class="manageTrainingSession-list">

                            <div><strong>Trainer First Name: </strong> @Session.TrainerFirstName </div>
                            <div><strong>Trainer Last Name: </strong> @Session.TrainerLastName </div>
                            <div><strong>Created At: </strong> @Session.CreatedAt </div>
                            <div><strong>Start Date: </strong> @Session.StartDate </div>
                            <div><strong>End Date: </strong> @Session.EndDate </div>
                            <div><strong>Capacity: </strong> @Session.Capacity </div>
                            <div><strong>Location: </strong> @Session.Location </div>

                            <div class="manageTrainingSession-buttons">
                                <div class="manageTrainingSession-editBtn">
                                    <a asp-controller="TrainingSession" asp-action="Update" asp-route-id="@Session.Id" class="manageTrainingSession-editBtnTxt">Update</a>
                                </div>
                                <form asp-controller="TrainingSession" asp-action="Delete" asp-route-id="@Session.Id" method="post">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="manageTrainingSession-deleteBtn">Delete</button>
                                </form>
                            </div>

                            <hr class="manageTrainingSession-line" />

                        </div>
                    }

                </div>
            }

                <div class="manageTrainingSession-formWrapper">
                    <h3 class="manageTrainingSession-h4">@((Model.Form.TrainerMemberId == Guid.Empty) ? "Create" : "Update") Membership Plan</h3>
                
                    <form asp-controller="TrainingSession" asp-action="@(Model.Form.TrainerMemberId == Guid.Empty ? "Create" : "Update")" method="post" novalidate>
                        @Html.AntiForgeryToken()

                        <div class="manageTrainingSession-formGroup ">
                            <label class="manageTrainingSession-label" asp-for="Form.TrainerMemberId"></label>


                            <!-- i got help by chatGPT to create this dropdown menue -->

                        <select asp-for="Form.TrainerMemberId" class="manageTrainingSession-input">
                                
                                <option value="" class="manageTrainingSession-input" >Select Trainer</option>

                                @foreach (var member in Model.Members)
                                    {
                                        <option value="@member.Id">
                                            @member.FirstName @member.LastName
                                        </option>
                                    }

                            </select>

                            <span class="manageTrainingSession-validation-error" asp-validation-for="Form.TrainerMemberId"></span>
                        </div>

                        <div class="manageTrainingSession-formGroup ">
                            <label class="manageTrainingSession-label" asp-for="Form.StartDate"></label>
                        <input class="manageTrainingSession-input" asp-for="Form.StartDate" type="datetime-local" />
                            <span class="manageTrainingSession-validation-error" asp-validation-for="Form.StartDate"></span>
                        </div>

                        <div class="manageTrainingSession-formGroup two">
                            <label class="manageTrainingSession-label" asp-for="Form.EndDate"></label>
                        <input class="manageTrainingSession-input" asp-for="Form.EndDate" type="datetime-local" />
                            <span class="manageTrainingSession-validation-error" asp-validation-for="Form.EndDate"></span>
                        </div>

                        <div class="manageTrainingSession-formGroup two">
                            <label class="manageTrainingSession-label" asp-for="Form.Capacity"></label>
                            <input class="manageTrainingSession-input" asp-for="Form.Capacity" />
                            <span class="manageTrainingSession-validation-error" asp-validation-for="Form.Capacity"></span>
                        </div>

                        <div class="manageTrainingSession-formGroup two">
                            <label class="manageTrainingSession-label" asp-for="Form.Location"></label>
                            <input class="manageTrainingSession-input" asp-for="Form.Location" />
                            <span class="manageTrainingSession-validation-error" asp-validation-for="Form.Location"></span>
                        </div>

                        <button type="submit" class="manageTrainingSession-from-Btn">@((Model.Form.TrainerMemberId == Guid.Empty) ? "Create" : "Update")</button>
                    </form>
                </div>

                <div class="manageTrainingSession-returnBtn">
                    <a asp-controller="Admin" asp-action="Index" class="manageTrainingSession-returnBtnTxt">Return</a>
                </div>
        </div>
    </div>
</div>